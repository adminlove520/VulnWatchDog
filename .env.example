# 调试模式
DEBUG=false

# 通知配置
ENABLE_NOTIFY=true
NOTIFY_TYPE=dingtalk  # 支持: dingtalk, feishu

# GPT配置
ENABLE_GPT=true
GPT_PROVIDER=minimax  # 支持: minimax, openai, fastgpt

# MiniMax配置（使用Anthropic官方SDK）
MINIMAX_API_KEY=your_minimax_api_key
MINIMAX_MODEL=MiniMax-M2.7
# 可选：自定义Anthropic API地址（默认不用改）
ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic

# OpenAI配置
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# FastGPT配置
FASTGPT_API_KEY=your_fastgpt_api_key
FASTGPT_API_URL=your_fastgpt_api_url
FASTGPT_MODEL=gpt-3.5-turbo

# 搜索配置
ENABLE_SEARCH=true
SEARCH_ENGINE=all  # 支持: duckduckgo, bing, all
ENABLE_EXTENDED=false

# CVE配置
CVE_YEAR_RANGE=2020-2025  # 例如: 2025-2026

# 数据库配置
DB_URL=sqlite:///vulns.db

# GitHub配置
GITHUB_TOKEN=your_github_token

# 钉钉通知配置
DINGTALK_WEBHOOK_URL=your_dingtalk_webhook_url
DINGTALK_SECRET=your_dingtalk_secret

# 飞书通知配置
FEISHU_WEBHOOK_URL=your_feishu_webhook_url
FEISHU_SECRET=your_feishu_secret

# 性能配置
SLEEP_INTERVAL=2